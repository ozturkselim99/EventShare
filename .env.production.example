# Production environment template — copy to .env on the server (never commit .env)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/eventshare

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://host:6379

# ─── JWT (generate with: openssl rand -base64 64) ─────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_PUBLIC_URL=https://eventshare.app
API_PUBLIC_URL=https://api.eventshare.app
API_PORT=3001

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eventshare-media
R2_PUBLIC_BASE_URL=https://media.eventshare.app
# R2_ENDPOINT is optional when R2_ACCOUNT_ID is set

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=50
MAX_VIDEO_SIZE_MB=500
PRESIGNED_URL_TTL_SECONDS=600

# ─── Next.js web ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.eventshare.app/api/v1
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://eventshare.app
