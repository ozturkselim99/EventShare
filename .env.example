# ─── Database ─────────────────────────────────────────────────────────────────
# Docker ile çalışıyorsa port 5433 kullanın
DATABASE_URL=postgresql://eventshare:eventshare_secret@localhost:5433/eventshare

# ─── QStash (job queue) ───────────────────────────────────────────────────────
# Local dev: `npx @upstash/qstash-cli dev` çalıştırıp çıktıdaki değerleri yapıştırın.
# Production: Upstash Console > QStash değerleri (docs/qstash-setup.md)
QSTASH_URL=http://127.0.0.1:8080
QSTASH_TOKEN=eyJVc2VySUQiOiJkZWZhdWx0VXNlciIsIlBhc3N3b3JkIjoiZGVmYXVsdFBhc3N3b3JkIn0=
QSTASH_CURRENT_SIGNING_KEY=sig_7kYjw48mhY7kAjqNGcy6cr29RJ6r
QSTASH_NEXT_SIGNING_KEY=sig_5ZB6DVzB1wjE8S6rZ7eenA8Pdnhs

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_PORT=3002
WORKER_PUBLIC_URL=http://localhost:3002

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin Seed ────────────────────────────────────────────────────────────────
# db:seed komutu ile oluşturulacak admin kullanıcısı
# ADMIN_EMAIL=admin@eventshare.app
# ADMIN_PASSWORD=Admin1234!

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
API_PORT=3001

# ─── Storage ───────────────────────────────────────────────────────────────────
# local = Geliştirme için yerel disk (varsayılan)
# r2 = Cloudflare R2 (local test veya production)
STORAGE_PROVIDER=local

# Cloudflare R2 — STORAGE_PROVIDER=r2 iken zorunlu
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET=eventshare-media
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# R2_ENDPOINT opsiyonel — R2_ACCOUNT_ID varsa otomatik türetilir
# Kurulum rehberi: docs/r2-setup.md
# Production şablonu: .env.production.example

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=50
MAX_VIDEO_SIZE_MB=500
DEFAULT_EVENT_STORAGE_QUOTA_GB=20
PRESIGNED_URL_TTL_SECONDS=600

# ─── Next.js web ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
